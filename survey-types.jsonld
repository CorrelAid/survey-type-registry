      },
      "limesurvey": {
        "typeCode": "X",
        "supportsOther": false,
        "answerClass": null
      },
      "ddi": {
        "intrvl": "discrete",
        "formatType": "character",
        "responseDomainType": "text"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 0,
        "dataStructure": "none",
        "warnings": [
          "Note questions don't collect data but are preserved in DDI"
        ]
      },
      "concept": {
        "openness": "none",
        "cardinality": "none",
        "dataNature": "none"
      }
    },
    {
      "@id": "type:date",
