      },
      "qwacback": {
        "answerType": "text"
      }
    },
    {
      "@id": "type:time",
      "@type": "QuestionType",
      "skos:prefLabel": "Time",
      "xlsform": {
        "typeString": "time"
      },
      "limesurvey": {
        "typeCode": "D",
        "supportsOther": false,
        "answerClass": null
      },
      "ddi": {
        "intrvl": "interval",
        "formatType": "character",
        "responseDomainType": "text"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 1,
        "dataStructure": "single-column",
        "warnings": [
          "LimeSurvey type D stores combined date+time; time-only granularity may be lost"
        ]
      },
      "concept": {
        "openness": "open",
        "cardinality": "single",
        "dataNature": "temporal"
      },
      "qwacback": {
        "answerType": "text"
      }
    },
    {
      "@id": "type:datetime",
      "@type": "QuestionType",
