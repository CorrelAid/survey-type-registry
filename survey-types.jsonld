{
  "@context": {
    "@vocab": "https://civic-data.de/survey/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "type:decimal",
      "@type": "QuestionType",
      "skos:prefLabel": "Decimal/Float",
      "xlsform": {
        "typeString": "decimal"
      },
      "limesurvey": {
        "typeCode": "N",
        "supportsOther": false,
        "answerClass": null
      },
      "ddi": {
        "intrvl": "contin",
        "formatType": "numeric",
        "responseDomainType": "numeric"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 1,
        "dataStructure": "single-column"
      },
      "concept": {
        "openness": "open",
        "cardinality": "single",
        "dataNature": "numeric"
      },
      "qwacback": {
        "answerType": "integer"
      }
    },
    {
      "@id": "type:note",
      "@type": "QuestionType",
      "skos:prefLabel": "Note (Display Text)",
      "xlsform": {
        "typeString": "note"
      },
      "limesurvey": {
        "typeCode": "X",
        "supportsOther": false,
        "answerClass": null
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 0,
        "dataStructure": "none",
        "warnings": [
          "Note questions don't collect data but are preserved in DDI"
        ]
      },
      "concept": {
        "openness": "none",
        "cardinality": "none",
        "dataNature": "none"
      }
    },
    {
      "@id": "type:time",
      "@type": "QuestionType",
      "skos:prefLabel": "Time",
      "xlsform": {
        "typeString": "time"
      },
      "limesurvey": {
        "typeCode": "D",
        "supportsOther": false,
        "answerClass": null
      },
      "ddi": {
        "intrvl": "discrete",
        "formatType": "character",
        "responseDomainType": "text"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 1,
        "dataStructure": "single-column",
        "warnings": [
          "LimeSurvey type D stores combined date+time; time-only granularity may be lost"
        ]
      },
      "concept": {
        "openness": "open",
        "cardinality": "single",
        "dataNature": "temporal"
      },
      "qwacback": {
        "answerType": "text"
      }
    },
    {
      "@id": "type:datetime",
      "@type": "QuestionType",
      "skos:prefLabel": "Date+Time",
      "xlsform": {
        "typeString": "datetime"
      },
      "limesurvey": {
        "typeCode": "D",
        "supportsOther": false,
        "answerClass": null
      },
      "ddi": {
        "intrvl": "discrete",
        "formatType": "character",
        "responseDomainType": "text"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 1,
