    {
      "@id": "convention:other",
      "@type": "GlobalConvention",
      "skos:prefLabel": "Or-Other Pattern",
      "rule": {
        "companionSuffix": "_other",
        "companionType": "text",
        "relevanceTemplate": "${{${name}}} = 'other'",
        "choiceCode": "other",
        "appliesTo": [
          "select_one",
          "select_multiple"
        ]
      }
    },
    {
      "@id": "convention:sanitization",
      "@type": "GlobalConvention",
      "skos:prefLabel": "Name & Choice Code Sanitization",
      "rule": {
        "name": {
          "maxLength": 20,
          "stripCharsRegex": "[_-]",
          "pattern": "^[a-zA-Z0-9]+$",
          "dedupStrategy": "numeric-suffix"
        },
        "choiceCode": {
          "maxLength": 5,
          "stripCharsRegex": "[_-]",
          "pattern": "^[a-zA-Z0-9]+$"
        }
      }
    },
    {
      "@id": "convention:columnMap",
      "@type": "XLSFormColumnMap",
      "skos:prefLabel": "XLSForm → LimeSurvey TSV Column Mapping",
      "map": [
        {
          "xlsform": "required",
          "lsTsv": "mandatory",
          "transform": "yes→Y, no→N or empty"
        },
        {
          "xlsform": "constraint",
          "lsTsv": "em_validation_q",
          "transform": "XPath → LimeSurvey EM expression"
        },
        {
          "xlsform": "constraint_message",
          "lsTsv": "validation",
          "transform": "passthrough"
        },
        {
          "xlsform": "default",
          "lsTsv": "default",
          "transform": "passthrough"
        },
        {
          "xlsform": "relevant",
          "lsTsv": "relevance",
          "transform": "XPath → LimeSurvey EM expression"
        },
        {
          "xlsform": "label",
          "lsTsv": "text",
          "transform": "Markdown → HTML; ${var} → {name}"
        },
        {
          "xlsform": "hint",
          "lsTsv": "help",
          "transform": "Markdown → HTML; ${var} → {name}"
        },
        {
          "xlsform": "name",
          "lsTsv": "name",
          "transform": "sanitize per convention:sanitization"
        }
      ]
    },
    {
      "@id": "vocab:iso_3166_1",
      "@type": "Vocabulary",
      "skos:prefLabel": "ISO 3166-1 country codes (alpha-2)",
      "xlsformFilename": "iso_3166_1.csv",
      "ddiVocab": "iso_3166_1",
      "vocabURI": "https://www.iso.org/iso-3166-country-codes.html",
      "standard": "ISO 3166-1",
      "description": "Two-letter country codes (e.g. DE, FR, US)."
    },
    {
      "@id": "convention:externalCodeList",
      "@type": "GlobalConvention",
      "skos:prefLabel": "External code list (long-list) pattern",
      "rule": {
        "xlsformTypePattern": "^select_(one|multiple)_from_file (?P<filename>[^ ]+\\.csv)$",
        "ddiVocabFromFilename": "stripExtension",
        "ddiEmission": "concept[@vocab='<vocab>'] in place of inline catgry; catgry MUST NOT be emitted",
        "structuralNote": "select_multiple_from_file emits a flat <var> with concept/@vocab, NOT a varGrp[@type='multipleResp'] with binary children. This differs from select_multiple.",
        "appliesTo": [
          "select_one_from_file",
          "select_multiple_from_file"
        ],
        "registeredVocabularies": [
          "vocab:iso_3166_1"
        ]
      }
    }
  ]
}
