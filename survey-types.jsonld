      },
      "limesurvey": {
        "typeCode": null,
        "supported": false
      },
      "pairedWith": {
        "@id": "type:begin_repeat"
      },
      "transformation": {
        "roundTripSafe": false,
        "lossless": false,
        "dataColumns": 0,
        "dataStructure": "nested-arrays-not-supported"
      }
    },
    {
      "@id": "type:select_one_from_file",
