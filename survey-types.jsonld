      "behavior": "warn",
      "validForTypes": [
        "select_one",
        "select_multiple"
      ],
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "appearance:horizontal",
      "@type": "Appearance",
      "skos:prefLabel": "Horizontal layout",
      "xlsform": {
        "appearanceString": "horizontal"
      },
      "supported": false,
      "behavior": "warn",
      "validForTypes": [
        "select_one",
        "select_multiple"
      ],
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "appearance:compact",
      "@type": "Appearance",
      "skos:prefLabel": "Compact layout",
      "xlsform": {
        "appearanceString": "compact"
      },
      "supported": false,
      "behavior": "warn",
      "validForTypes": [
        "select_one",
        "select_multiple"
      ],
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "appearance:quickcompact",
      "@type": "Appearance",
      "skos:prefLabel": "Quick compact layout",
      "xlsform": {
        "appearanceString": "quickcompact"
      },
      "supported": false,
      "behavior": "warn",
      "validForTypes": [
        "select_one",
        "select_multiple"
      ],
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "appearance:signature",
      "@type": "Appearance",
      "skos:prefLabel": "Signature capture",
      "xlsform": {
        "appearanceString": "signature"
      },
      "supported": false,
      "behavior": "warn",
      "lsEffect": "Warned; ignored (not supported in LS TSV)"
    },
    {
      "@id": "appearance:draw",
      "@type": "Appearance",
      "skos:prefLabel": "Free draw capture",
      "xlsform": {
        "appearanceString": "draw"
      },
      "supported": false,
      "behavior": "warn",
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "appearance:map",
      "@type": "Appearance",
      "skos:prefLabel": "Map picker",
      "xlsform": {
        "appearanceString": "map"
      },
      "supported": false,
      "behavior": "warn",
      "validForTypes": [
        "geopoint",
        "geotrace",
        "geoshape"
      ],
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "appearance:quick map",
      "@type": "Appearance",
      "skos:prefLabel": "Quick map picker",
      "xlsform": {
        "appearanceString": "quick map"
      },
      "supported": false,
      "behavior": "warn",
      "validForTypes": [
        "geopoint",
        "geotrace",
        "geoshape"
      ],
      "lsEffect": "Warned; ignored"
    },
    {
      "@id": "convention:other",
      "@type": "GlobalConvention",
      "skos:prefLabel": "Or-Other Pattern",
      "rule": {
        "companionSuffix": "_other",
        "companionType": "text",
        "relevanceTemplate": "${{${name}}} = 'other'",
        "choiceCode": "other",
        "appliesTo": [
          "select_one",
          "select_multiple"
        ]
      }
    },
    {
      "@id": "convention:sanitization",
      "@type": "GlobalConvention",
      "skos:prefLabel": "Name & Choice Code Sanitization",
      "rule": {
        "name": {
          "maxLength": 20,
          "stripCharsRegex": "[_-]",
          "pattern": "^[a-zA-Z0-9]+$",
          "dedupStrategy": "numeric-suffix"
        },
        "choiceCode": {
          "maxLength": 5,
          "stripCharsRegex": "[_-]",
          "pattern": "^[a-zA-Z0-9]+$"
        }
      }
    },
    {
      "@id": "convention:columnMap",
      "@type": "XLSFormColumnMap",
      "skos:prefLabel": "XLSForm → LimeSurvey TSV Column Mapping",
      "map": [
        {
          "xlsform": "required",
          "lsTsv": "mandatory",
          "transform": "yes→Y, no→N or empty"
        },
        {
          "xlsform": "constraint",
          "lsTsv": "em_validation_q",
          "transform": "XPath → LimeSurvey EM expression"
        },
        {
          "xlsform": "constraint_message",
          "lsTsv": "validation",
          "transform": "passthrough"
        },
        {
          "xlsform": "default",
          "lsTsv": "default",
          "transform": "passthrough"
        },
        {
          "xlsform": "relevant",
          "lsTsv": "relevance",
          "transform": "XPath → LimeSurvey EM expression"
        },
        {
          "xlsform": "label",
          "lsTsv": "text",
          "transform": "Markdown → HTML; ${var} → {name}"
        },
        {
          "xlsform": "hint",
          "lsTsv": "help",
          "transform": "Markdown → HTML; ${var} → {name}"
        },
        {
          "xlsform": "name",
          "lsTsv": "name",
          "transform": "sanitize per convention:sanitization"
        }
      ]
    },
    {
      "@id": "vocab:iso_3166_1",
      "@type": "Vocabulary",
      "skos:prefLabel": "ISO 3166-1 country codes (alpha-2)",
      "xlsformFilename": "iso_3166_1.csv",
      "ddiVocab": "iso_3166_1",
      "vocabURI": "https://www.iso.org/iso-3166-country-codes.html",
      "standard": "ISO 3166-1",
      "description": "Two-letter country codes (e.g. DE, FR, US)."
    },
    {
      "@id": "convention:externalCodeList",
      "@type": "GlobalConvention",
      "skos:prefLabel": "External code list (long-list) pattern",
      "rule": {
        "xlsformTypePattern": "^select_(one|multiple)_from_file (?P<filename>[^ ]+\\.csv)$",
        "ddiVocabFromFilename": "stripExtension",
        "ddiEmission": "concept[@vocab='<vocab>'] in place of inline catgry; catgry MUST NOT be emitted",
        "structuralNote": "select_multiple_from_file emits a flat <var> with concept/@vocab, NOT a varGrp[@type='multipleResp'] with binary children. This differs from select_multiple.",
        "appliesTo": [
          "select_one_from_file",
          "select_multiple_from_file"
        ],
        "registeredVocabularies": [
          "vocab:iso_3166_1"
        ]
      }
    },
    {
      "@id": "convention:surveySettings",
      "@type": "GlobalConvention",
      "skos:prefLabel": "XLSForm `settings` sheet ↔ LS TSV ↔ DDI",
      "rule": {
        "fields": [
          {
            "xlsformKey": "form_title",
            "lsTsvRow": "SL surveyls_title",
            "ddiPath": "stdyDscr/citation/titlStmt/titl",
            "required": true
          },
          {
            "xlsformKey": "form_id",
            "lsTsvRow": null,
            "ddiPath": "fileDscr/@ID",
            "required": true
          },
          {
            "xlsformKey": "default_language",
            "lsTsvCell": "language column on every row",
            "ddiPath": "fallback xml:lang on var/qstn elements",
            "required": false
          },
          {
            "xlsformKey": "version",
            "lsTsvRow": null,
            "ddiPath": "codeBook/@version (DDI version, not survey version — record survey version elsewhere)",
            "required": false
          },
          {
            "xlsformKey": "instance_name",
            "lsTsvRow": null,
            "ddiPath": "fileDscr/fileTxt/fileName",
            "required": false
          }
        ],
        "magicNames": [
          {
            "xlsformRow": "type=note + name=welcome",
            "lsTsvRow": "SL surveyls_welcometext",
            "ddiPath": "stdyDscr/stdyInfo/abstract (or notes)",
            "note": "Body text from label promoted to survey-level intro. Convention only; opt-in via tool config."
          },
          {
            "xlsformRow": "type=note + name=end",
            "lsTsvRow": "SL surveyls_endtext",
            "ddiPath": "—",
            "note": "End-of-survey thank-you. LS-only."
          }
        ]
      }
    },
    {
      "@id": "convention:languageTagging",
      "@type": "GlobalConvention",
      "skos:prefLabel": "XLSForm `label::<lang>` ↔ LS TSV `language` cell ↔ DDI `xml:lang`",
      "rule": {
        "xlsformColumnPattern": "^(?P<base>label|hint|constraint_message|guidance_hint|media::image|media::audio|media::video)::(?P<lang>.+)$",
        "xlsformLanguageList": {
          "setting": "settings.default_language",
          "fallback": "first language encountered in label columns",
          "note": "Each language code SHOULD be a valid IETF BCP 47 tag (e.g. 'de', 'en', 'fr-BE'). Tools may warn on non-BCP47 codes."
        },
        "lsTsvHandling": {
          "column": "language",
          "emission": "one row per language per question — same name/type, different language column + text/help cells",
          "baseLanguage": "first emitted; subsequent languages reference same question name"
        },
        "ddiHandling": {
          "attribute": "xml:lang",
          "appliesToElements": [
            "txt",
            "qstnLit",
            "labl",
            "preQTxt",
            "postQTxt"
          ],
          "emission": "one child element per language with xml:lang attr"
        }
      }
    },
    {
      "@id": "composite:multiple_response",
      "@type": "Composite",
      "skos:prefLabel": "Multiple Response (binary fan-out)",
      "skos:broader": {
        "@id": "type:select_multiple"
      },
      "trigger": {
        "xlsformPattern": "single row, type='select_multiple <listname>'",
        "applyTo": "the row itself"
      },
      "input": {
        "rows": [
          {
            "role": "question",
            "match": "type=select_multiple <listname>",
            "cardinality": 1
          }
        ]
      },
      "output": {
        "ddi": {
          "container": "varGrp[@type='multipleResp']",
          "containerAttrs": {
            "name": "<question name>",
            "var": "space-separated IDs of member binary vars"
          },
          "memberVars": "one <var> per choice, name=<qname>_<choicecode>, intrvl='discrete', responseDomainType='multiple', binary catgry codes 0/1",
          "otherVariant": "if `or_other` flag present: parent varGrp[@type='other'] wraps the multipleResp group + a sibling _other text var; see convention:other"
        },
        "lsTsv": {
          "row": "Q-class row, type/scale=M, answerClass=SQ",
          "answerRows": "one A-class row per choice"
        }
      },
      "schematronPatterns": [
        "essentials",
        "logic"
      ]
    },
    {
      "@id": "composite:grid",
      "@type": "Composite",
      "skos:prefLabel": "Grid / Matrix Group",
      "skos:broader": [
        {
          "@id": "type:begin_group"
        },
        {
          "@id": "type:select_one"
        }
      ],
      "trigger": {
        "xlsformPattern": "begin_group row with appearance=table-list (or name contains 'grid', or label contains 'matrix')",
        "applyTo": "begin_group + all rows until matching end_group"
      },
      "input": {
        "rows": [
          {
            "role": "header",
            "match": "type=begin_group, appearance=table-list",
            "cardinality": 1
          },
          {
            "role": "item",
            "match": "type=select_one <listname> — all items MUST share the same listname",
            "cardinality": "1..*"
          },
          {
            "role": "closer",
            "match": "type=end_group",
            "cardinality": 1
          }
        ]
      },
      "output": {
        "ddi": {
          "container": "varGrp[@type='grid']",
          "containerAttrs": {
            "name": "<group name>",
            "var": "space-separated member IDs"
          },
          "memberVars": "one <var> per item row. Each var carries the full <catgry> set repeated (responseDomainType='category')."
        },
        "lsTsv": {
          "headerRow": "F-type question (matrix header) with answerClass=A; answer codes from shared list",
          "itemRows": "SQ-class rows, one per item",
          "note": "LS represents the matrix as a single question with sub-questions; categories not re-emitted per row"
        }
      },
      "schematronPatterns": [
        "essentials",
        "logic"
      ],
      "notes": [
        "If `appearance=table-list` is absent, the group is flattened — children become top-level vars in DDI, group is lost.",
        "Items SHOULD share the same `listname` so the matrix is rectangular."
      ]
    },
    {
      "@id": "composite:other_pattern",
      "@type": "Composite",
      "skos:prefLabel": "Semi-open `or_other` pattern (companion text var)",
      "skos:broader": [
        {
          "@id": "type:select_one"
        },
        {
          "@id": "type:select_multiple"
        }
      ],
      "trigger": {
        "xlsformPattern": "select_one|select_multiple row with `or_other` flag in type cell, immediately followed (or anywhere later in same scope) by a text row named `<basename>_other`",
        "applyTo": "the base row + the `<basename>_other` companion row"
      },
      "input": {
        "rows": [
          {
            "role": "base",
            "match": "type=select_one|select_multiple <listname> or_other, name=<basename>",
            "cardinality": 1
          },
          {
            "role": "companion",
            "match": "type=text, name=<basename>_other, relevant=${<basename>} = 'other'",
            "cardinality": 1
          }
        ]
      },
      "output": {
        "ddi": {
          "container": "varGrp[@type='other']",
          "containerAttrs": {
            "name": "<basename>",
            "var": "for single-choice: '<base_var_ID> <other_var_ID>'. For multiple-choice: var=<other_var_ID>, varGrp=<base_multipleResp_groupID>"
          },
          "childStructure": "single-choice: parent varGrp + base <var> + _other text <var>. multiple-choice: parent varGrp + child multipleResp varGrp (named <basename>_choices) + _other text <var> as SIBLING (NOT inside multipleResp's @var list)"
        },
        "lsTsv": {
          "baseRow": "Q-class row with other='Y'",
          "companionRow": "Q-class S-type row, relevance: '<basename> == \"other\"'"
        }
      },
      "schematronPatterns": [
        "other_variables"
      ],
      "notes": [
        "Choice with code 'other' MUST exist in the base question's list.",
        "For multiple_choice_other: the _other text var must NOT appear in the multipleResp group's @var attribute.",
        "DDI→XLSForm direction reconstructs relevance from the parent varGrp[@type='other'] reference."
      ]
    }
  ]
}
