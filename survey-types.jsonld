        "answerType": "text"
      }
    },
    {
      "@id": "type:calculate",
      "@type": "QuestionType",
      "skos:prefLabel": "Calculated Field",
      "xlsform": {
        "typeString": "calculate"
      },
      "limesurvey": {
        "typeCode": "*",
        "supportsOther": false,
        "answerClass": null
      },
      "ddi": {
        "intrvl": "discrete",
        "formatType": "character",
        "responseDomainType": "text"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": false,
        "dataColumns": 1,
        "dataStructure": "single-column",
        "warnings": [
          "XPath expressions transpiled to ExpressionScript may not be fully equivalent"
        ]
      },
      "concept": {
        "openness": "none",
        "cardinality": "none",
        "dataNature": "text"
      }
    },
    {
      "@id": "type:begin_repeat",
      "@type": "StructuralType",
      "skos:prefLabel": "Repeat Group",
      "xlsform": {
        "typeString": "begin_repeat"
      },
      "limesurvey": {
        "typeCode": null,
        "supported": false
      },
      "ddi": {
        "preservation": "none",
        "conditions": [
          {
            "if": "always",
            "then": "SKIPPED - variables inside repeats are not exported"
          }
        ]
      },
      "kobo": {
        "nativeSupport": true,
        "dataStructure": "nested-arrays"
      },
      "transformation": {
        "roundTripSafe": false,
        "lossless": false,
        "dataColumns": 0,
        "dataStructure": "nested-arrays-not-supported",
        "warnings": [
          "Repeat groups not supported in LimeSurvey or DDI export",
          "Variables inside begin_repeat/end_repeat are silently skipped",
          "Requires different data model (nested arrays) not currently implemented"
        ]
      }
    },
    {
      "@id": "type:end_group",
      "@type": "StructuralType",
      "skos:prefLabel": "Group (End)",
      "xlsform": {
        "typeString": "end_group"
      },
      "limesurvey": {
        "typeCode": null,
        "supported": true,
        "emitsGroupRow": false
      },
      "pairedWith": {
        "@id": "type:begin_group"
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 0,
        "dataStructure": "none"
      }
    },
    {
      "@id": "type:end_repeat",
      "@type": "StructuralType",
      "skos:prefLabel": "Repeat Group (End)",
      "xlsform": {
        "typeString": "end_repeat"
      },
      "limesurvey": {
        "typeCode": null,
        "supported": false
      },
      "pairedWith": {
        "@id": "type:begin_repeat"
      },
      "transformation": {
        "roundTripSafe": false,
        "lossless": false,
        "dataColumns": 0,
        "dataStructure": "nested-arrays-not-supported"
      }
    },
