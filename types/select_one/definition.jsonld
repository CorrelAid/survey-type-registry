{
  "@context": {
    "@vocab": "https://civic-data.de/survey/",
    "skos": "http://www.w3.org/2004/02/skos/core#"
  },
  "@graph": [
    {
      "@id": "type:select_one",
      "@type": "QuestionType",
      "skos:prefLabel": "Single Choice (Radio Buttons)",
      "xlsform": {
        "typeString": "select_one",
        "requiresListName": true
      },
      "limesurvey": {
        "typeCode": "L",
        "supportsOther": true,
        "answerClass": "A"
      },
      "ddi": {
        "intrvl": "discrete",
        "formatType": "numeric",
        "responseDomainType": "category"
      },
      "kobo": {
        "nativeSupport": true
      },
      "constraints": {
        "maxNameLength": 20,
        "namePattern": "^[a-zA-Z0-9]+$",
        "maxChoiceCodeLength": 5,
        "choiceCodePattern": "^[a-zA-Z0-9]+$",
        "warnings": [
          "Choice codes > 5 chars will be truncated in LimeSurvey"
        ]
      },
      "transformation": {
        "roundTripSafe": true,
        "lossless": true,
        "dataColumns": 1,
        "dataStructure": "single-column",
        "warnings": [
          "Choice code truncation can cause ambiguity if two codes share 5-char prefix"
        ]
      },
      "concept": {
        "openness": "closed",
        "cardinality": "single",
        "dataNature": "categorical"
      },
      "qwacback": {
        "answerType": "single_choice"
      },
      "tier": "v1-blessed",
      "frozenSince": "2026-05-20",
      "variants": [
        "variant:single_choice",
        "variant:single_choice_other",
        "variant:single_choice_long_list"
      ],
      "tests": [
        "tests/types/select_one/"
      ]
    }
  ]
}
